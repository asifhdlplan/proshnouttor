# =============================================================
#  Proshnouttor — Environment Variables
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proshnouttor?schema=public"

# ── NextAuth ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="proshnouttor-dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:5173"

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Email / SMTP ──────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your@gmail.com"
EMAIL_SERVER_PASSWORD="your-gmail-app-password"
EMAIL_FROM="Proshnouttor <noreply@proshnouttor.com>"

# ── Vite public vars ──────────────────────────────────────────
VITE_APP_NAME="Proshnouttor"
VITE_APP_URL="http://localhost:5173"
